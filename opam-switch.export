package "ppx_fuelproof" {
  opam-version: "2.0"
  version: "v0.18~preview.130.91+190"
  synopsis: "Get better error messages and improve mode crossing for types"
  description: """\
ppx_fuelproof helps work around several issues when trying to make your
type mode-cross in the way you want:

  1. It generates better error messages when your type doesn't mode-cross.
  2. It helps you avoid running out of fuel. (The mode-crossing check in
     the compiler limits how hard it will try to prove mode-crossing.)
  3. It lets you have some amount of mode-crossing GADTs."""
  maintainer: "Jane Street developers"
  authors: "Jane Street Group, LLC"
  license: "MIT"
  homepage: "https://github.com/janestreet/ppx_fuelproof"
  doc:
    "https://ocaml.janestreet.com/ocaml-core/latest/doc/ppx_fuelproof/index.html"
  bug-reports: "https://github.com/janestreet/ppx_fuelproof/issues"
  depends: [
    "ocaml" {>= "5.1.0"}
    "base" {= "v0.18~preview.130.91+190"}
    "ppx_compare" {= "v0.18~preview.130.91+190"}
