    "ppx_sexp_conv" {= "v0.18~preview.130.91+190"}
    "ppxlib_jane" {= "v0.18~preview.130.91+190"}
    "dune" {>= "3.17.0"}
    "ppxlib" {>= "0.33.0"}
  ]
  conflicts: [
    "oxcaml-compiler" {< "5.2.0minus31"}
  ]
  available: arch != "arm32" & arch != "x86_32"
  build: ["dune" "build" "-p" name "-j" jobs]
